{
  "name": "peernest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --no-isolate --pool=forks",
    "test:watch": "vitest",
    "db:dev": "pglite-server --db ./.data/peernest --host 127.0.0.1 --port 55432 --max-connections 10",
    "db:dev:reset": "tsx scripts/init-dev-db.ts && npm run db:seed",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "arctic": "^3.7.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.9",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@electric-sql/pglite-socket": "^0.1.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
